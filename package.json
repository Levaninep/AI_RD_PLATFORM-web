{
  "name": "@ai-rd/root",
  "version": "1.0.0",
  "description": "AI R&D Platform - Monorepo",
  "private": true,
  "workspaces": [
    "backend",
    "shared",
    "web"
  ],
  "scripts": {
    "install:web": "node scripts/install-web.cjs",
    "postinstall": "node scripts/install-web.cjs",
    "dev": "npm --prefix web run dev",
    "build": "npm --prefix web run build",
    "start": "npm --prefix web run start",
    "lint": "npm --prefix web run lint",
    "dev:web": "npm --prefix web run dev",
    "build:web": "npm --prefix web run build",
    "start:web": "npm --prefix web run start",
    "lint:web": "npm --prefix web run lint",
    "dev:backend": "npm --prefix backend run dev",
    "deploy:vercel": "npx vercel deploy --prod --yes ."
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
